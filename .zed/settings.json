	"lsp": {
		"zls": {
			"initialization_options": {
				"usePlaceholders": false,
			},
			"settings": {
				"build_on_save": true,
				"use_placeholders": false,
				"build_on_save_args": [
					"-fincremental",
					"-Dallow_lzo=true",
					"-Ddebug=true",
				],
			},
		},
	},
}
